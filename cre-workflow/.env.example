# CRE Workflow — environment variables
# Copy to .env and fill in your values before simulating

# UrbanLeaf FastAPI backend (must be running and publicly accessible for CRE)
URBANLEAF_API_URL=http://localhost:4000

# Gemini AI — get from https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Arbitrum Sepolia RPC
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# UrbanLeafCommunity.sol deployed address on Arbitrum Sepolia
CONTRACT_ADDRESS=0xYourContractAddress

# CRE worker private key — this wallet must be the contract owner
# (so it can call setEnvironmentalScore and updateProposalStatus)
PRIVATE_KEY=your-wallet-private-key-without-0x

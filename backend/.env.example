# UrbanLeaf AI — Backend (Python FastAPI)

# Gemini AI
GEMINI_API_KEY=

# Google Earth Engine
GEE_PROJECT_ID=

# Blockchain Service (Node.js, runs on port 5000)
BLOCKCHAIN_SERVICE_URL=http://localhost:5000

# Chainlink Runtime Environment (CRE) — score-proposal workflow HTTP trigger
# Set this to the CRE node's HTTP trigger URL once deployed.
# Leave blank to skip CRE scoring (proposals still create on-chain, just without AI score).
# For local simulation: cre workflow simulate score-proposal
CRE_WORKFLOW_URL=

PORT=4000

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=
APP_URL=http://localhost:3000
